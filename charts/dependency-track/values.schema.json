{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "Values",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "global": {
      "type": "object",
      "description": "Builtin Helm value; required so the chart validates when used as a subchart (ref helm/helm#10392)"
    },
    "nameOverride": {
      "type": "string"
    },
    "fullnameOverride": {
      "type": "string"
    },
    "enableServiceLinks": {
      "type": "boolean"
    },
    "image": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "registry": {
          "type": "string"
        },
        "pullSecrets": {
          "$ref": "#/$defs/objectArray"
        }
      }
    },
    "serviceAccount": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "create": {
          "type": "boolean"
        },
        "annotations": {
          "type": "object"
        },
        "name": {
          "type": "string"
        }
      }
    },
    "database": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "jdbcUrl": {
          "type": "string"
        },
        "username": {
          "type": "string"
        },
        "password": {
          "type": "string"
        },
        "existingSecret": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "name": {
              "type": "string"
            },
            "usernameKey": {
              "type": "string"
            },
            "passwordKey": {
              "type": "string"
            }
          }
        }
      }
    },
    "fileStorage": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "provider": {
          "enum": [
            "local",
            "s3"
          ]
        },
        "local": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "existingClaim": {
              "type": "string"
            },
            "size": {
              "type": "string"
            },
            "storageClassName": {
              "type": "string"
            },
            "accessModes": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "mountPath": {
              "type": "string"
            }
          }
        },
        "s3": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "endpoint": {
              "type": "string"
            },
            "region": {
              "type": "string"
            },
            "bucket": {
              "type": "string"
            },
            "credentials": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "existingSecret": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "name": {
                      "type": "string"
                    },
                    "accessKeyIdKey": {
                      "type": "string"
                    },
                    "secretAccessKeyKey": {
                      "type": "string"
                    }
                  }
                },
                "accessKeyId": {
                  "type": "string"
                },
                "secretAccessKey": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "secretManagement": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "provider": {
          "enum": [
            "database",
            "env"
          ]
        },
        "database": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "kek": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "mode": {
                  "enum": [
                    "config",
                    "keyset"
                  ]
                },
                "value": {
                  "type": "string"
                },
                "existingSecret": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "name": {
                      "type": "string"
                    },
                    "key": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "apiServer": {
      "$ref": "#/$defs/apiServer"
    },
    "frontend": {
      "$ref": "#/$defs/frontend"
    },
    "ingress": {
      "$ref": "#/$defs/ingress"
    },
    "httpRoute": {
      "$ref": "#/$defs/httpRoute"
    },
    "extraObjects": {
      "$ref": "#/$defs/objectArray"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "fileStorage": {
            "properties": {
              "provider": {
                "const": "s3"
              }
            }
          }
        }
      },
      "then": {
        "properties": {
          "fileStorage": {
            "properties": {
              "s3": {
                "required": [
                  "endpoint",
                  "region",
                  "bucket"
                ],
                "properties": {
                  "endpoint": {
                    "minLength": 1
                  },
                  "region": {
                    "minLength": 1
                  },
                  "bucket": {
                    "minLength": 1
                  }
                }
              }
            }
          }
        }
      }
    }
  ],
  "$defs": {
    "apiServer": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "topology": {
          "enum": [
            "monolith",
            "split"
          ]
        },
        "image": {
          "$ref": "#/$defs/image"
        },
        "command": {
          "$ref": "#/$defs/stringArray"
        },
        "args": {
          "$ref": "#/$defs/stringArray"
        },
        "annotations": {
          "type": "object"
        },
        "podSecurityContext": {
          "type": [
            "object",
            "null"
          ]
        },
        "securityContext": {
          "type": [
            "object",
            "null"
          ]
        },
        "service": {
          "$ref": "#/$defs/serviceWithManagement"
        },
        "serviceMonitor": {
          "$ref": "#/$defs/serviceMonitor"
        },
        "probes": {
          "$ref": "#/$defs/probes"
        },
        "deployment": {
          "$ref": "#/$defs/deployment"
        },
        "extraEnv": {
          "$ref": "#/$defs/envArray"
        },
        "extraEnvFrom": {
          "$ref": "#/$defs/objectArray"
        },
        "extraContainers": {
          "$ref": "#/$defs/objectArray"
        },
        "initContainers": {
          "$ref": "#/$defs/objectArray"
        },
        "additionalVolumes": {
          "$ref": "#/$defs/volumeArray"
        },
        "additionalVolumeMounts": {
          "$ref": "#/$defs/volumeMountArray"
        },
        "podAnnotations": {
          "type": "object"
        },
        "podLabels": {
          "type": "object"
        },
        "web": {
          "$ref": "#/$defs/role"
        },
        "worker": {
          "$ref": "#/$defs/role"
        },
        "initializer": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "backoffLimit": {
              "type": "integer"
            },
            "resources": {
              "type": "object"
            },
            "podAnnotations": {
              "type": "object"
            },
            "initContainers": {
              "type": "array"
            }
          }
        }
      }
    },
    "frontend": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "replicaCount": {
          "type": "number",
          "minimum": 0
        },
        "annotations": {
          "type": "object"
        },
        "image": {
          "$ref": "#/$defs/image"
        },
        "command": {
          "$ref": "#/$defs/stringArray"
        },
        "args": {
          "$ref": "#/$defs/stringArray"
        },
        "resources": {
          "$ref": "#/$defs/resources"
        },
        "podSecurityContext": {
          "type": [
            "object",
            "null"
          ]
        },
        "securityContext": {
          "type": [
            "object",
            "null"
          ]
        },
        "extraEnv": {
          "$ref": "#/$defs/envArray"
        },
        "extraEnvFrom": {
          "$ref": "#/$defs/objectArray"
        },
        "extraContainers": {
          "$ref": "#/$defs/objectArray"
        },
        "initContainers": {
          "$ref": "#/$defs/objectArray"
        },
        "additionalVolumes": {
          "$ref": "#/$defs/volumeArray"
        },
        "additionalVolumeMounts": {
          "$ref": "#/$defs/volumeMountArray"
        },
        "podAnnotations": {
          "type": "object"
        },
        "podLabels": {
          "type": "object"
        },
        "tolerations": {
          "$ref": "#/$defs/objectArray"
        },
        "nodeSelector": {
          "type": "object"
        },
        "affinity": {
          "type": "object"
        },
        "topologySpreadConstraints": {
          "$ref": "#/$defs/objectArray"
        },
        "priorityClassName": {
          "type": "string"
        },
        "revisionHistoryLimit": {
          "type": "number"
        },
        "probes": {
          "$ref": "#/$defs/probes"
        },
        "service": {
          "$ref": "#/$defs/service"
        },
        "apiBaseUrl": {
          "type": "string"
        },
        "deployment": {
          "$ref": "#/$defs/deployment"
        },
        "autoscaling": {
          "$ref": "#/$defs/hpaAutoscaling"
        },
        "pdb": {
          "$ref": "#/$defs/pdb"
        }
      }
    },
    "ingress": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "annotations": {
          "type": "object"
        },
        "labels": {
          "type": "object"
        },
        "hostname": {
          "type": "string"
        },
        "ingressClassName": {
          "type": "string"
        },
        "tls": {
          "$ref": "#/$defs/objectArray"
        }
      }
    },
    "httpRoute": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "annotations": {
          "type": "object"
        },
        "labels": {
          "type": "object"
        },
        "hostnames": {
          "$ref": "#/$defs/stringArray"
        },
        "parentRefs": {
          "$ref": "#/$defs/objectArray"
        }
      }
    },
    "image": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "registry": {
          "type": "string"
        },
        "repository": {
          "type": "string"
        },
        "tag": {
          "type": [
            "null",
            "string"
          ]
        },
        "pullPolicy": {
          "enum": [
            "Always",
            "IfNotPresent",
            "Never"
          ]
        }
      }
    },
    "service": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": {
          "enum": [
            "ClusterIP",
            "NodePort",
            "LoadBalancer",
            "ExternalName"
          ]
        },
        "nodePort": {
          "type": [
            "null",
            "number"
          ],
          "description": "Valid NodePort range is 30000-32767 (Kubernetes default).",
          "minimum": 30000,
          "maximum": 32767
        },
        "port": {
          "type": "number"
        },
        "annotations": {
          "type": "object"
        }
      }
    },
    "serviceWithManagement": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": {
          "enum": [
            "ClusterIP",
            "NodePort",
            "LoadBalancer",
            "ExternalName"
          ]
        },
        "nodePort": {
          "type": [
            "null",
            "number"
          ],
          "minimum": 30000,
          "maximum": 32767
        },
        "port": {
          "type": "number"
        },
        "managementPort": {
          "type": "number"
        },
        "annotations": {
          "type": "object"
        }
      }
    },
    "deployment": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "strategy": {
          "type": [
            "object",
            "null"
          ],
          "additionalProperties": false,
          "properties": {
            "type": {
              "enum": [
                "RollingUpdate",
                "Recreate"
              ]
            },
            "rollingUpdate": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "maxSurge": {
                  "type": [
                    "string",
                    "number"
                  ]
                },
                "maxUnavailable": {
                  "type": [
                    "string",
                    "number"
                  ]
                }
              }
            }
          }
        }
      }
    },
    "objectArray": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "stringArray": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "envArray": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "value": {
            "type": [
              "string",
              "number",
              "boolean"
            ]
          },
          "valueFrom": {
            "type": "object"
          }
        },
        "oneOf": [
          {
            "required": [
              "value"
            ]
          },
          {
            "required": [
              "valueFrom"
            ]
          }
        ]
      }
    },
    "volumeArray": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "volumeMountArray": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "mountPath"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "mountPath": {
            "type": "string",
            "pattern": "^/"
          }
        }
      }
    },
    "probe": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "failureThreshold": {
          "type": "number"
        },
        "initialDelaySeconds": {
          "type": "number"
        },
        "periodSeconds": {
          "type": "number"
        },
        "successThreshold": {
          "type": "number"
        },
        "timeoutSeconds": {
          "type": "number"
        }
      }
    },
    "probes": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "startup": {
          "$ref": "#/$defs/probe"
        },
        "readiness": {
          "$ref": "#/$defs/probe"
        },
        "liveness": {
          "$ref": "#/$defs/probe"
        }
      }
    },
    "resources": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "requests": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "cpu": {
              "type": [
                "string",
                "number"
              ]
            },
            "memory": {
              "type": "string"
            }
          }
        },
        "limits": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "cpu": {
              "type": [
                "string",
                "number"
              ]
            },
            "memory": {
              "type": "string"
            }
          }
        }
      }
    },
    "serviceMonitor": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "namespace": {
          "type": "string"
        },
        "scrapeInterval": {
          "type": "string"
        },
        "scrapeTimeout": {
          "type": "string"
        },
        "labels": {
          "type": "object"
        }
      }
    },
    "hpaAutoscaling": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "annotations": {
          "type": "object"
        },
        "minReplicas": {
          "type": "number",
          "minimum": 1
        },
        "maxReplicas": {
          "type": "number",
          "minimum": 1
        },
        "targetCPUUtilizationPercentage": {
          "type": [
            "null",
            "number"
          ]
        },
        "targetMemoryUtilizationPercentage": {
          "type": [
            "null",
            "number"
          ]
        },
        "behavior": {
          "type": "object"
        }
      }
    },
    "pdb": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "minAvailable": {
          "type": [
            "null",
            "number",
            "string"
          ]
        },
        "maxUnavailable": {
          "type": [
            "null",
            "number",
            "string"
          ]
        }
      }
    },
    "role": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "replicaCount": {
          "type": "number",
          "minimum": 0
        },
        "autoscaling": {
          "$ref": "#/$defs/hpaAutoscaling"
        },
        "pdb": {
          "$ref": "#/$defs/pdb"
        },
        "resources": {
          "$ref": "#/$defs/resources"
        },
        "revisionHistoryLimit": {
          "type": "number"
        },
        "priorityClassName": {
          "type": "string"
        },
        "terminationGracePeriodSeconds": {
          "type": "number"
        },
        "extraEnv": {
          "$ref": "#/$defs/envArray"
        },
        "extraEnvFrom": {
          "$ref": "#/$defs/objectArray"
        },
        "tolerations": {
          "$ref": "#/$defs/objectArray"
        },
        "nodeSelector": {
          "type": "object"
        },
        "affinity": {
          "type": "object"
        },
        "topologySpreadConstraints": {
          "type": "array",
          "items": {
            "type": "object"
          }
        }
      }
    }
  }
}
